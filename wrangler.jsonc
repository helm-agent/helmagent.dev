{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "helmagent-dev",
  "compatibility_date": "2026-05-01",
  "assets": {
    "directory": "./public",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "helmagent.dev", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  }
}
